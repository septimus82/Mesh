{
  "wizard": "new-region",
  "version": 1,
  "inputs": {
    "subcommand": "new-region",
    "name_prefix": "Ashen",
    "scene": null,
    "pack": "core_regions",
    "plan": "ashen_region.plan.json",
    "apply": false,
    "dry_run": false,
    "into_world": "worlds/main_world.json",
    "link_from": null,
    "profile": "safe",
    "npc_role": "quest_giver",
    "quest_type": "fetch",
    "list": false,
    "run": null,
    "vars": null
  },
  "actions": [
    {
      "type": "create_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "template": "overworld"
      },
      "description": "Create hub scene 'Ashen_hub'"
    },
    {
      "type": "create_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "template": "interior"
      },
      "description": "Create interior scene 'Ashen_interior'"
    },
    {
      "type": "create_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_dungeon.json",
        "template": "interior"
      },
      "description": "Create dungeon scene 'Ashen_dungeon'"
    },
    {
      "type": "add_npc",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "name": "Ashen_Merchant",
        "role": "merchant",
        "quest_id": null
      },
      "description": "Add Merchant to Hub"
    },
    {
      "type": "add_npc",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "name": "Ashen_Guard",
        "role": "guard",
        "quest_id": null
      },
      "description": "Add Guard to Hub"
    },
    {
      "type": "add_npc",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "name": "Ashen_Elder",
        "role": "quest_giver",
        "quest_id": "Ashen_fetch_quest"
      },
      "description": "Add Elder to Interior"
    },
    {
      "type": "create_quest",
      "args": {
        "path": "packs\\core_regions\\assets\\data\\quests.json",
        "id": "Ashen_fetch_quest",
        "title": "Ashen Fetch",
        "type": "fetch"
      },
      "description": "Create Fetch Quest"
    },
    {
      "type": "create_quest",
      "args": {
        "path": "packs\\core_regions\\assets\\data\\quests.json",
        "id": "Ashen_kill_quest",
        "title": "Ashen Hunt",
        "type": "kill"
      },
      "description": "Create Kill Quest"
    },
    {
      "type": "wire_world",
      "args": {
        "world_path": "worlds/main_world.json",
        "scene_path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "scene_id": "Ashen_hub"
      },
      "description": "Register Ashen_hub in world"
    },
    {
      "type": "wire_world",
      "args": {
        "world_path": "worlds/main_world.json",
        "scene_path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "scene_id": "Ashen_interior"
      },
      "description": "Register Ashen_interior in world"
    },
    {
      "type": "wire_world",
      "args": {
        "world_path": "worlds/main_world.json",
        "scene_path": "packs\\core_regions\\scenes\\Ashen_dungeon.json",
        "scene_id": "Ashen_dungeon"
      },
      "description": "Register Ashen_dungeon in world"
    },
    {
      "type": "wire_world",
      "args": {
        "world_path": "worlds/main_world.json",
        "scene_path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "scene_id": "Ashen_interior",
        "link_from": "Ashen_hub"
      },
      "description": "Link Hub <-> Interior"
    },
    {
      "type": "wire_world",
      "args": {
        "world_path": "worlds/main_world.json",
        "scene_path": "packs\\core_regions\\scenes\\Ashen_dungeon.json",
        "scene_id": "Ashen_dungeon",
        "link_from": "Ashen_hub"
      },
      "description": "Link Hub <-> Dungeon"
    },
    {
      "type": "auto_wire_transitions",
      "args": {
        "world_path": "worlds/main_world.json"
      },
      "description": "Auto-wire transitions"
    },
    {
      "type": "polish_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "compact_only": false
      },
      "description": "Polish Ashen_hub.json"
    },
    {
      "type": "validate",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_hub.json",
        "check_refs": false
      },
      "description": "Validate Ashen_hub.json"
    },
    {
      "type": "polish_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "compact_only": false
      },
      "description": "Polish Ashen_interior.json"
    },
    {
      "type": "validate",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_interior.json",
        "check_refs": false
      },
      "description": "Validate Ashen_interior.json"
    },
    {
      "type": "polish_scene",
      "args": {
        "path": "packs\\core_regions\\scenes\\Ashen_dungeon.json",
        "compact_only": false
      },
      "description": "Polish Ashen_dungeon.json"
    },
    {
      "type": "validate",
      "args": {
        "scene_path": "packs\\core_regions\\scenes\\Ashen_dungeon.json",
        "check_refs": false
      },
      "description": "Validate Ashen_dungeon.json"
    }
  ]
}