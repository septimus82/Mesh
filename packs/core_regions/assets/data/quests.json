{
  "quests": [
    {
      "id": "ridge_fetch_supplies",
      "title": "Supplies for the Ridge",
      "description": "The Ridge Outpost is running low on supplies. Retrieve the lost shipment.",
      "stages": [
        {
          "id": "collect_supplies",
          "title": "Find the Supplies",
          "text": "Locate the missing supply crate near the old road.",
          "complete_on": {
            "type": "collectible_picked",
            "payload": {
              "collectible_name": "RidgeSupplies"
            }
          }
        },
        {
          "id": "return_supplies",
          "title": "Return to Merchant",
          "text": "Bring the supplies back to the Ridge Merchant.",
          "complete_on": {
            "type": "dialogue_choice",
            "payload": {
              "entity": "RidgeMerchant",
              "choice_id": "ridge_turnin"
            }
          }
        }
      ],
      "reward": {
        "inc_counters": {
          "xp": 100,
          "gold": 50
        }
      }
    },
    {
