  "encounter-balance-sweep": {
    "description": "Full encounter balance analysis",
    "steps": [
      {
        "args": [
          "worlds/main_world.json",
          "--only-dungeons",
          "--themes",
          "moss,magma,void",
          "--difficulty",
          "easy,normal,hard",
          "--out",
          ".mesh/reports/encounter_report_full.json",
          "--json"
        ],
        "cmd": "encounter-report"
      }
    ]
  },
  "encounter-ci": {
    "description": "Run encounter report for CI",
    "steps": [
      {
        "args": [
          "worlds/main_world.json",
          "--only-dungeons",
          "--difficulty",
          "easy,normal,hard",
          "--out",
          ".mesh/reports/encounter_report.json",
          "--json"
        ],
        "cmd": "encounter-report"
      }
    ]
  },
  "encounter-ci-diff": {
    "description": "Compare encounter report against baseline",
    "steps": [
      {
        "args": [
          "encounter-ci"
        ],
        "cmd": "run-preset"
      },
      {
        "args": [
          "diff",
          ".mesh/reports/encounter_report_baseline.json",
          ".mesh/reports/encounter_report.json",
          "--max-elite-delta",
          "0",
          "--max-spawn-delta",
          "2",
          "--fail-on-overrun"
        ],
        "cmd": "encounter-report"
      }
    ]
  },
